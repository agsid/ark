---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
---

<Layout title="ARK | Command Center">
  <Header />

  <div class="md:hidden flex border-b border-slate-200 bg-white sticky top-16 z-40">
    <button id="tab-sensors" class="flex-1 py-4 text-xs font-black uppercase tracking-widest text-indigo-600 border-b-2 border-indigo-600">Sensors</button>
    <button id="tab-environment" class="flex-1 py-4 text-xs font-black uppercase tracking-widest text-slate-400">Environment</button>
    <button id="tab-map" class="flex-1 py-4 text-xs font-black uppercase tracking-widest text-slate-400">Location</button>
  </div>

  <main class="p-4 md:p-8 bg-[#fcfdfe] min-h-screen">
    <div class="max-w-7xl mx-auto">
      
      <div id="dashboard-grid" class="grid grid-cols-1 md:grid-cols-12 gap-6">
        
        <div id="section-sensors" class="md:col-span-6 space-y-6">
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em] mb-2">Security Arrays</h3>
            
            <div class="bg-white/40 backdrop-blur-xl border border-white/40 p-6 rounded-[2rem] shadow-xl shadow-indigo-100/20 relative overflow-hidden group">
                <div class="flex justify-between items-start relative z-10">
                    <div>
                        <p class="text-[10px] font-black text-indigo-600 uppercase tracking-widest">Lid Proximity</p>
                        <div class="flex items-baseline gap-2 mt-2">
                            <span id="dist-lid" class="text-5xl font-black text-slate-900 tabular tracking-tighter">0.00</span>
                            <span class="text-sm font-bold text-slate-300">CM</span>
                        </div>
                    </div>
                    <div id="badge-lid" class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-100">Secured</div>
                </div>
                <div class="mt-4 h-1 bg-slate-100 rounded-full overflow-hidden">
                    <div id="bar-lid" class="h-full bg-indigo-500 transition-all duration-500 w-0"></div>
                </div>
            </div>

            <div class="bg-white/40 backdrop-blur-xl border border-white/40 p-6 rounded-[2rem] shadow-xl shadow-indigo-100/20 relative overflow-hidden group">
                <div class="flex justify-between items-start relative z-10">
                    <div>
                        <p class="text-[10px] font-black text-cyan-600 uppercase tracking-widest">Relic Tracker</p>
                        <div class="flex items-baseline gap-2 mt-2">
                            <span id="dist-relic" class="text-5xl font-black text-slate-900 tabular tracking-tighter">0.00</span>
                            <span class="text-sm font-bold text-slate-300">CM</span>
                        </div>
                    </div>
                    <div id="badge-relic" class="px-3 py-1 rounded-full text-[10px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-100">Present</div>
                </div>
                <div class="mt-4 h-1 bg-slate-100 rounded-full overflow-hidden">
                    <div id="bar-relic" class="h-full bg-cyan-500 transition-all duration-500 w-0"></div>
                </div>
            </div>
        </div>

        <div id="section-environment" class="md:col-span-6 space-y-6 hidden md:block">
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em] mb-2">Environmental Analysis</h3>
            <div class="grid grid-cols-2 gap-4">
                <div class="bg-white border border-slate-200 p-4 rounded-2xl shadow-sm">
                    <p class="text-[9px] font-bold text-slate-400 uppercase">Temp</p>
                    <p class="text-2xl font-black text-slate-900"><span id="val-temp">--</span>°C</p>
                </div>
                <div class="bg-white border border-slate-200 p-4 rounded-2xl shadow-sm">
                    <p class="text-[9px] font-bold text-slate-400 uppercase">AQI</p>
                    <p class="text-2xl font-black text-slate-900"><span id="val-aqi">--</span></p>
                </div>
            </div>
            <div class="bg-slate-900 rounded-[2rem] p-6 h-64 shadow-2xl relative overflow-hidden group">
                <p class="text-[10px] font-bold text-indigo-400 uppercase tracking-widest mb-4">Atmospheric Stability (10m)</p>
                <canvas id="envChart"></canvas>
            </div>
        </div>

        <div id="section-map" class="md:col-span-12 hidden md:block">
            <h3 class="text-xs font-black text-slate-400 uppercase tracking-[0.2em] mb-4">Deployment Location</h3>
            <div class="w-full h-80 bg-slate-200 rounded-[2.5rem] shadow-inner overflow-hidden relative">
                <iframe 
                    class="w-full h-full grayscale contrast-125" 
                    src="https://www.google.com/maps/embed?pb=!1m14!1m12!1m3!1d10000!2d-0!3d0!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!5e0!3m2!1sen!2sus!4v1" 
                    style="border:0;" allowfullscreen="" loading="lazy">
                </iframe>
                <div class="absolute inset-0 pointer-events-none ring-1 ring-inset ring-black/5 rounded-[2.5rem]"></div>
            </div>
        </div>
      </div>
    </div>
  </main>

  <div id="notification-toast" class="fixed top-24 right-6 z-[100] w-80 translate-x-[120%] transition-all duration-500">
    <div class="bg-white/90 backdrop-blur-2xl border border-rose-100 p-4 rounded-3xl shadow-2xl flex gap-4 items-center ring-1 ring-rose-500/20">
      <div class="w-12 h-12 bg-rose-500 rounded-2xl flex items-center justify-center text-white">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
      </div>
      <div>
        <p id="alert-title" class="text-sm font-black text-slate-900 leading-tight">Alert</p>
        <p id="alert-body" class="text-[11px] text-slate-500 font-medium">Monitoring active.</p>
      </div>
    </div>
  </div>

  <script>
    import { db } from "../lib/firebase";
    import { ref, onValue } from "firebase/database";
    import Chart from 'chart.js/auto';

    // 1. MOBILE TAB LOGIC
    const tabs = {
        sensors: document.getElementById('tab-sensors'),
        env: document.getElementById('tab-environment'),
        map: document.getElementById('tab-map')
    };
    const sections = {
        sensors: document.getElementById('section-sensors'),
        env: document.getElementById('section-environment'),
        map: document.getElementById('section-map')
    };

    Object.keys(tabs).forEach(key => {
        tabs[key]?.addEventListener('click', () => {
            Object.values(sections).forEach(s => s?.classList.add('hidden', 'md:block'));
            Object.values(tabs).forEach(t => t?.classList.replace('text-indigo-600', 'text-slate-400'));
            Object.values(tabs).forEach(t => t?.classList.remove('border-b-2', 'border-indigo-600'));
            
            sections[key]?.classList.remove('hidden');
            tabs[key]?.classList.replace('text-slate-400', 'text-indigo-600');
            tabs[key]?.classList.add('border-b-2', 'border-indigo-600');
        });
    });

    // 2. CHART CONFIG
    const ctx = (document.getElementById('envChart') as HTMLCanvasElement)?.getContext('2d');
    const envChart = new Chart(ctx!, {
        type: 'line',
        data: { labels: [], datasets: [{ label: 'Temp', data: [], borderColor: '#6366f1', tension: 0.4, fill: true, backgroundColor: 'rgba(99, 102, 241, 0.1)' }] },
        options: { plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { grid: { color: '#1e293b' }, ticks: { color: '#64748b' } } } }
    });

    // 3. DATA STREAM & LOGIC
    let alertLock = false;
    onValue(ref(db, 'sensor'), (snapshot) => {
        const data = snapshot.val() || {};
        const lid = data.lid_distance ?? 0;
        const relic = data.relic_distance ?? 0;

        // Disregard > 100
        if(lid > 100 || relic > 100) return;

        // Update UI Text
        document.getElementById('dist-lid')!.innerText = lid.toFixed(1);
        document.getElementById('dist-relic')!.innerText = relic.toFixed(1);
        document.getElementById('val-temp')!.innerText = data.temp?.toFixed(1) || '--';
        document.getElementById('val-aqi')!.innerText = data.aqi || '--';

        // Update Progress Bars
        document.getElementById('bar-lid')!.style.width = `${Math.min(lid, 100)}%`;
        document.getElementById('bar-relic')!.style.width = `${Math.min(relic, 100)}%`;

        // ALERTS
        const lidOpen = lid > 5;
        const relicGone = relic > 20;

        if (relicGone) triggerAlert("Artifact Missing", "Relic tracker reports target removed.");
        else if (lidOpen) triggerAlert("Lid Breached", "Box lid is currently open.");

        // Update Badges
        updateBadge('badge-lid', lidOpen, "Breached", "Secured");
        updateBadge('badge-relic', relicGone, "Missing", "Present");

        // Update Chart
        if(data.temp) {
            envChart.data.labels!.push('');
            envChart.data.datasets[0].data.push(data.temp);
            if(envChart.data.labels!.length > 20) { envChart.data.labels!.shift(); envChart.data.datasets[0].data.shift(); }
            envChart.update();
        }
    });

    function updateBadge(id, isError, errorText, okText) {
        const el = document.getElementById(id);
        if(!el) return;
        el.innerText = isError ? errorText : okText;
        el.className = isError 
            ? "px-3 py-1 rounded-full text-[10px] font-black uppercase bg-rose-50 text-rose-600 border border-rose-100"
            : "px-3 py-1 rounded-full text-[10px] font-black uppercase bg-emerald-50 text-emerald-600 border border-emerald-100";
    }

    function triggerAlert(title, body) {
        if(alertLock) return;
        const toast = document.getElementById('notification-toast');
        document.getElementById('alert-title')!.innerText = title;
        document.getElementById('alert-body')!.innerText = body;
        toast?.classList.remove('translate-x-[120%]');
        alertLock = true;
        setTimeout(() => {
            toast?.classList.add('translate-x-[120%]');
            setTimeout(() => { alertLock = false; }, 5000);
        }, 4000);
    }
  </script>
</Layout>