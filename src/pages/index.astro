---
import DashboardLayout from '../layouts/DashboardLayout.astro';
import GlassCard from '../components/GlassCard.astro';
import Notifications from '../components/Notifications.astro';
---

<DashboardLayout title="ARK | Live Telemetry">
  <Notifications />
  
  <div class="space-y-6 pb-24 md:pb-6">
    
    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4">
      
      <GlassCard class="p-4 flex flex-col items-center justify-center min-h-[140px]">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400 mb-3">Temp</span>
        <div class="relative size-20">
          <svg class="size-full -rotate-90" viewBox="0 0 36 36">
            <circle cx="18" cy="18" r="16" fill="none" class="stroke-slate-100" stroke-width="3"></circle>
            <circle id="temp-gauge" cx="18" cy="18" r="16" fill="none" class="stroke-orange-500 transition-all duration-700" stroke-width="3" stroke-dasharray="0, 100" stroke-linecap="round"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center text-lg font-semibold text-slate-900">
            <span id="temp-val">--</span>°
          </div>
        </div>
      </GlassCard>

      <GlassCard class="p-5 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Humidity</span>
        <div class="flex items-baseline gap-1">
          <span id="hum-val" class="text-3xl font-light text-slate-900">--</span>
          <span class="text-xs font-mono text-slate-400">%</span>
        </div>
        <div class="w-full h-1.5 bg-slate-100/50 rounded-full overflow-hidden">
          <div id="hum-bar" class="h-full bg-blue-500 transition-all duration-1000" style="width: 0%"></div>
        </div>
      </GlassCard>

      <GlassCard class="p-5 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Pressure</span>
        <div class="flex flex-col mt-2">
          <span id="pres-val" class="text-3xl font-light text-slate-900 tabular-nums">10</span>
          <span class="text-[10px] font-mono text-slate-400 uppercase tracking-tighter">hPa</span>
        </div>
      </GlassCard>

      <GlassCard class="p-5 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-400">Gas Index</span>
        <div class="flex items-baseline gap-1">
          <span id="gas-val" class="text-3xl font-light text-slate-900">--</span>
        </div>
        <div id="gas-status" class="text-[9px] font-bold text-slate-400 uppercase tracking-widest">Scanning</div>
      </GlassCard>

      <GlassCard class="p-5 bg-slate-900/90 border-slate-700/50 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Vault Lid</span>
        <span id="lid-status" class="text-xl font-bold uppercase tracking-tight text-white">---</span>
        <div id="dist-1-led" class="size-2 rounded-full bg-slate-700 transition-all"></div>
      </GlassCard>

      <GlassCard class="p-5 bg-slate-900/90 border-slate-700/50 flex flex-col justify-between">
        <span class="text-[10px] font-bold uppercase tracking-widest text-slate-500">Artifact</span>
        <span id="artifact-status" class="text-xl font-bold uppercase tracking-tight text-white">---</span>
        <div id="dist-2-led" class="size-2 rounded-full bg-slate-700 transition-all"></div>
      </GlassCard>

    </div>

    <GlassCard class="p-2 relative overflow-hidden group">
      <div id="ark-map" class="h-[400px] w-full rounded-[26px] bg-slate-50 z-10"></div>
      <button id="save-loc-btn" class="absolute bottom-8 right-8 z-[1000] bg-orange-600 text-white px-6 py-3 rounded-2xl text-[11px] font-bold uppercase tracking-widest shadow-2xl shadow-orange-600/40 hover:bg-orange-700 hover:scale-105 active:scale-95 transition-all flex items-center gap-2">
        <svg xmlns="http://www.w3.org/2000/svg" class="size-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3"><path stroke-linecap="round" stroke-linejoin="round" d="M12 4v16m8-8H4" /></svg>
        Log Position
      </button>
    </GlassCard>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <GlassCard class="p-6">
        <h3 class="text-[11px] font-bold text-slate-900 uppercase tracking-widest mb-6">Environment Metrics</h3>
        <div class="h-64"><canvas id="envChart"></canvas></div>
      </GlassCard>
      
      <GlassCard class="p-6">
        <h3 class="text-[11px] font-bold text-slate-900 uppercase tracking-widest mb-6">Motion Analytics (CM)</h3>
        <div class="h-64"><canvas id="motionChart"></canvas></div>
      </GlassCard>
    </div>

  </div>
</DashboardLayout>
<script>
  import Chart from 'chart.js/auto';
  import L from 'leaflet';
  import 'leaflet/dist/leaflet.css';
  import { db, auth } from '../lib/firebase';
  import { ref, onValue, push, serverTimestamp } from 'firebase/database';

  let currentCoords = { lat: 0, lng: 0 };
  
  // --- SYSTEM STATE TRACKER (For Notifications) ---
  let systemState = {
    lidOpen: false,
    artifactPresent: true,
    lastTemp: null
  };

  // --- 1. Notification Helper ---
  const sendAlert = (title, body) => {
    if ("Notification" in window && Notification.permission === "granted") {
      new Notification(`ARK ALERT: ${title}`, { body, icon: '/favicon.svg' });
      if (navigator.vibrate) navigator.vibrate([200, 100, 200]);
    }
  };

  // Request Permission on first interaction
  window.addEventListener('click', () => {
    if ("Notification" in window && Notification.permission === "default") {
      Notification.requestPermission();
    }
  }, { once: true });

  // --- 2. Map & Chart Init ---
  const map = L.map('ark-map', { zoomControl: false, attributionControl: false }).setView([0, 0], 2);
  L.tileLayer('https://{s}.basemaps.cartocdn.com/rastertiles/voyager/{z}/{x}/{y}{r}.png').addTo(map);
  const marker = L.marker([0, 0], { icon: L.divIcon({ className: 'ark-marker', iconSize: [14, 14], iconAnchor: [7, 7] }) }).addTo(map);

  const envChart = new Chart(document.getElementById('envChart'), {
    type: 'line',
    data: { labels: [], datasets: [
      { label: 'Temp', data: [], borderColor: '#ea580c', borderWidth: 2, pointRadius: 0, tension: 0.4 },
      { label: 'Hum', data: [], borderColor: '#3b82f6', borderWidth: 2, pointRadius: 0, tension: 0.4 },
      { label: 'Gas', data: [], borderColor: '#10b981', borderWidth: 2, pointRadius: 0, tension: 0.4 }
    ]},
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: true, labels: { boxWidth: 8, font: { size: 9 } } } }, scales: { x: { display: false }, y: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 9 } } } } }
  });

  const motionChart = new Chart(document.getElementById('motionChart'), {
    type: 'line',
    data: { labels: [], datasets: [
      { label: 'Lid Sensor', data: [], borderColor: '#6366f1', borderWidth: 2, pointRadius: 0, tension: 0.4 },
      { label: 'Art. Sensor', data: [], borderColor: '#a855f7', borderWidth: 2, pointRadius: 0, tension: 0.4 }
    ]},
    options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: true, labels: { boxWidth: 8, font: { size: 9 } } } }, scales: { x: { display: false }, y: { grid: { color: '#f1f5f9' }, ticks: { font: { size: 9 } } } } }
  });

  // --- 3. Firebase Connectivity ---
  auth.onAuthStateChanged(async (user) => {
    if (!user) return;

    const userLinkRef = ref(db, `software/user/${user.uid}/linked_device`);
    onValue(userLinkRef, (snapshot) => {
      const activeId = snapshot.val() || "586294"; 
      const deviceRef = ref(db, `hardware/${activeId}`);
      
      onValue(deviceRef, (hwSnapshot) => {
        const data = hwSnapshot.val();
        if (!data) return;

        const { environment, motion, last_seen, last_seen_gps } = data;

        // --- ENVIRONMENT LOGIC ---
        if (environment) {
          document.getElementById('temp-val').textContent = environment.temp.toFixed(1);
          document.getElementById('temp-gauge').setAttribute('stroke-dasharray', `${(environment.temp / 50) * 100}, 100`);
          document.getElementById('hum-val').textContent = Math.round(environment.humidity);
          document.getElementById('hum-bar').style.width = `${environment.humidity}%`;
          document.getElementById('pres-val').textContent = Math.round(environment.pressure);
          document.getElementById('gas-val').textContent = Math.round(environment.gas);

          // Anomaly Check: Temp jump > 2.5 degrees
          if (systemState.lastTemp !== null && Math.abs(environment.temp - systemState.lastTemp) > 2.5) {
            sendAlert("Environment Change", `Rapid temp shift detected: ${environment.temp.toFixed(1)}°C`);
          }
          systemState.lastTemp = environment.temp;
        }

        // --- MOTION LOGIC (Lid & Artifact) ---
        if (motion) {
          const s1 = motion.sensor_1_cm || 0;
          const s2 = motion.sensor_2_cm || 0;

          // Lid Check (S1 > 10 is open)
          const currentLidOpen = s1 > 10;
          const lidEl = document.getElementById('lid-status');
          lidEl.textContent = currentLidOpen ? "OPENED" : "CLOSED";
          lidEl.className = currentLidOpen ? "text-lg font-bold text-orange-500 animate-pulse" : "text-lg font-bold text-emerald-500";
          document.getElementById('dist-1-led').className = currentLidOpen ? "size-1.5 rounded-full bg-orange-500 animate-ping" : "size-1.5 rounded-full bg-emerald-500";

          if (currentLidOpen !== systemState.lidOpen) {
            if (currentLidOpen) sendAlert("Security", "Vault Lid has been OPENED.");
            systemState.lidOpen = currentLidOpen;
          }

          // Artifact Check (S2 > 10 is missing)
          const currentArtMissing = s2 > 10;
          const artEl = document.getElementById('artifact-status');
          artEl.textContent = currentArtMissing ? "MISSING" : "SECURED";
          artEl.className = currentArtMissing ? "text-lg font-bold text-red-500 animate-bounce" : "text-lg font-bold text-blue-400";
          document.getElementById('dist-2-led').className = currentArtMissing ? "size-1.5 rounded-full bg-red-500 animate-ping" : "size-1.5 rounded-full bg-blue-400";

          if (currentArtMissing !== !systemState.artifactPresent) {
            if (currentArtMissing) sendAlert("Critical", "The Artifact has been REMOVED!");
            systemState.artifactPresent = !currentArtMissing;
          }
        }

        // --- GPS & HEADER ---
        if (window.updateHeaderStatus) window.updateHeaderStatus(activeId, last_seen);
        if (data.gps && data.gps.lat) {
            currentCoords = { lat: data.gps.lat, lng: data.gps.lng };
            marker.setLatLng([currentCoords.lat, currentCoords.lng]);
            map.panTo([currentCoords.lat, currentCoords.lng]);
        }

        // --- CHARTS UPDATE ---
        const time = new Date().toLocaleTimeString([], { hour: '2-digit', minute: '2-digit', second: '2-digit', hour12: false });
        
        envChart.data.labels.push(time);
        envChart.data.datasets[0].data.push(environment.temp);
        envChart.data.datasets[1].data.push(environment.humidity);
        envChart.data.datasets[2].data.push(environment.gas);

        motionChart.data.labels.push(time);
        motionChart.data.datasets[0].data.push(motion.sensor_1_cm);
        motionChart.data.datasets[1].data.push(motion.sensor_2_cm);

        [envChart, motionChart].forEach(c => {
          if (c.data.labels.length > 30) {
            c.data.labels.shift();
            c.data.datasets.forEach(ds => ds.data.shift());
          }
          c.update('none');
        });
      });
    });

    // Save Location History
    document.getElementById('save-loc-btn')?.addEventListener('click', async () => {
      try {
        await push(ref(db, `software/user/${user.uid}/location_history`), { ...currentCoords, capturedAt: serverTimestamp() });
        const btn = document.getElementById('save-loc-btn');
        btn.textContent = "Saved ✓";
        setTimeout(() => { btn.textContent = "Log Position"; }, 2000);
      } catch (err) { console.error(err); }
    });
  });
</script>