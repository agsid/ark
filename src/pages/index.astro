---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="ARK | Live Telemetry">
  <div class="space-y-4 md:space-y-6 pb-24 md:pb-0">
    
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-3 md:gap-4">
      
      <div class="bg-white p-5 rounded-[28px] border border-slate-200 shadow-xs flex flex-col items-center">
        <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400 mb-3">Temperature</span>
        <div class="relative size-24">
          <svg class="size-full -rotate-90" viewBox="0 0 36 36">
            <circle cx="18" cy="18" r="16" fill="none" class="stroke-slate-100" stroke-width="3"></circle>
            <circle id="temp-gauge" cx="18" cy="18" r="16" fill="none" class="stroke-orange-500 transition-all duration-700" stroke-width="3" stroke-dasharray="0, 100" stroke-linecap="round"></circle>
          </svg>
          <div class="absolute inset-0 flex items-center justify-center text-xl font-light" id="temp-val">--</div>
        </div>
      </div>

      <div class="bg-white p-5 rounded-[28px] border border-slate-200 shadow-xs flex flex-col justify-between">
        <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Humidity</span>
        <div class="flex items-baseline gap-1 my-2">
          <span id="hum-val" class="text-4xl font-light text-slate-900">--</span>
          <span class="text-xs font-mono text-slate-400">%</span>
        </div>
        <div class="w-full h-1.5 bg-slate-100 rounded-full overflow-hidden">
          <div id="hum-bar" class="h-full bg-blue-500 transition-all duration-1000" style="width: 0%"></div>
        </div>
      </div>

      <div class="bg-slate-900 p-5 rounded-[28px] shadow-lg flex flex-col justify-between overflow-hidden relative group">
        <div class="absolute inset-0 opacity-10 bg-[linear-gradient(to_right,#80808012_1px,transparent_1px),linear-gradient(to_bottom,#80808012_1px,transparent_1px)] bg-[size:10px_10px]"></div>
        
        <span class="text-[9px] font-bold uppercase tracking-widest text-slate-500 relative z-10">Proximity</span>
        <div class="flex items-baseline gap-1 my-2 relative z-10">
          <span id="dist-val" class="text-4xl font-light text-white tabular-nums">---</span>
          <span class="text-xs font-mono text-slate-500 uppercase">cm</span>
        </div>
        <div class="flex items-center gap-2 relative z-10">
          <div id="dist-led" class="size-1.5 rounded-full bg-slate-700"></div>
          <span class="text-[8px] font-mono text-slate-500 uppercase tracking-tighter">Sensor Node 01</span>
        </div>
      </div>

      <div class="bg-white p-5 rounded-[28px] border border-slate-200 shadow-xs flex flex-col justify-between">
        <span class="text-[9px] font-bold uppercase tracking-widest text-slate-400">Gas</span>
        <div class="flex items-baseline gap-1 my-2">
          <span id="gas-val" class="text-4xl font-light text-slate-900">--</span>
          <span class="text-xs font-mono text-slate-400">ppm</span>
        </div>
        <div id="gas-status" class="text-[8px] font-bold uppercase py-1 px-2 rounded-md bg-slate-100 text-slate-400 self-start">Checking...</div>
      </div>
    </div>

    <div class="bg-white p-1.5 rounded-[32px] border border-slate-200 shadow-xs overflow-hidden">
      <div 
        id="ark-map" 
        class="h-56 md:h-80 w-full rounded-[26px] bg-slate-50 z-10 touch-pan-y pointer-events-auto"
      ></div>
    </div>

    <div class="bg-white p-5 md:p-8 rounded-[32px] border border-slate-200 shadow-xs">
      <div class="flex items-center justify-between mb-6">
        <h3 class="text-xs font-bold text-slate-900 uppercase tracking-widest">Telemetry Stream</h3>
        <div id="anomaly-pip" class="size-2 bg-green-500 rounded-full"></div>
      </div>
      <div class="h-48 md:h-72">
        <canvas id="envChart"></canvas>
      </div>
    </div>

  </div>
</DashboardLayout>

<script>
  import Chart from 'chart.js/auto';
  import L from 'leaflet';

  // --- 1. Map Fix for Mobile ---
  // We disable 'scrollWheelZoom' and 'tap' so users can scroll past the map on phone
  const map = L.map('ark-map', { 
    zoomControl: false,
    scrollWheelZoom: false, // Prevent desktop scroll trap
    dragging: !L.Browser.mobile, // Prevent mobile swipe trap
    tap: false,
    touchZoom: 'center' 
  }).setView([0, 0], 2);

  L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png').addTo(map);
  const marker = L.circleMarker([0,0], { radius: 7, fillColor: '#ea580c', color: '#fff', weight: 2, fillOpacity: 1 }).addTo(map);

  // Allow clicking to re-enable dragging (Native app behavior)
  map.on('click', () => { map.dragging.enable(); });

  // --- 2. Chart Init ---
  const ctx = document.getElementById('envChart') as HTMLCanvasElement;
  const chart = new Chart(ctx, {
    type: 'line',
    data: {
      labels: [],
      datasets: [{
        data: [],
        borderColor: '#ea580c',
        backgroundColor: 'rgba(234, 88, 12, 0.05)',
        fill: true,
        tension: 0.4,
        borderWidth: 2,
        pointRadius: 0,
        segment: {
          borderColor: (c) => Math.abs(c.p1.parsed.y - c.p0.parsed.y) > 1.5 ? '#ef4444' : '#ea580c',
        }
      }]
    },
    options: {
      responsive: true,
      maintainAspectRatio: false,
      plugins: { legend: { display: false } },
      scales: {
        x: { display: false },
        y: { grid: { color: '#f8fafc' }, ticks: { font: { size: 9 } } }
      }
    }
  });

  // --- 3. Firebase Event Listener ---
  window.addEventListener('ark-telemetry', (e: any) => {
    const data = e.detail;
    
    // Environment Data
    const { temp, humidity, gas } = data.environment;
    document.getElementById('temp-val').textContent = temp.toFixed(1);
    document.getElementById('temp-gauge').setAttribute('stroke-dasharray', `${(temp / 50) * 100}, 100`);
    document.getElementById('hum-val').textContent = Math.round(humidity);
    document.getElementById('hum-bar').style.width = `${humidity}%`;
    document.getElementById('gas-val').textContent = Math.round(gas);

    // Distance Sensor (Motion Data)
    const distance = data.motion.sensor_1_cm;
    const distEl = document.getElementById('dist-val');
    const distLed = document.getElementById('dist-led');
    
    if (distEl) distEl.textContent = Math.round(distance).toString();
    
    // Logic: Change LED color if something is close (under 50cm)
    if (distLed) {
      if (distance < 50) {
        distLed.className = "size-1.5 rounded-full bg-red-500 animate-ping";
        if ('vibrate' in navigator) navigator.vibrate(50); // Haptic feedback for proximity
      } else {
        distLed.className = "size-1.5 rounded-full bg-green-400 shadow-[0_0_8px_#4ade80]";
      }
    }

    // Update Chart
    const time = new Date().toLocaleTimeString();
    chart.data.labels?.push(time);
    chart.data.datasets[0].data.push(temp);
    if (chart.data.labels!.length > 15) {
      chart.data.labels?.shift();
      chart.data.datasets[0].data.shift();
    }
    chart.update('none');
  });
</script>