---
import '../styles/global.css';
---

<html lang="en">
<head>
  <title>Allied Algos | Telemetry</title>
</head>
<body class="bg-[#020408] text-slate-400 font-sans p-4 md:p-8">

  <header class="max-w-7xl mx-auto flex flex-col md:flex-row justify-between items-start md:items-center mb-12 gap-4">
    <div>
      <h2 class="text-white font-black text-3xl tracking-tighter uppercase">Allied <span class="text-cyan-500">Relic</span></h2>
      <p class="text-[10px] tracking-[0.4em] uppercase text-slate-600">Secure Sensor Network // Node-01</p>
    </div>
    <div class="flex gap-4 items-center">
      <div id="sync-status" class="flex items-center gap-2 px-4 py-2 bg-slate-900/50 border border-slate-800 rounded-sm text-[10px] font-bold uppercase tracking-widest">
        <span class="h-1.5 w-1.5 bg-slate-700 rounded-full"></span> Offline
      </div>
      <button id="logout" class="text-[10px] uppercase font-bold tracking-widest hover:text-white transition-colors">Disconnect</button>
    </div>
  </header>

  <main class="max-w-7xl mx-auto grid grid-cols-1 md:grid-cols-4 gap-4">
    
    <div class="md:col-span-2 bg-[#0a0f1a] border border-slate-800 p-8 rounded-sm group relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-cyan-500 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500 mb-6 italic">Distance Array _ Alpha</p>
        <div class="flex items-baseline gap-4">
            <span id="dist-1" class="text-8xl font-light text-white tracking-tighter">0.00</span>
            <span class="text-xl font-bold text-slate-700">MM</span>
        </div>
    </div>

    <div class="md:col-span-2 bg-[#0a0f1a] border border-slate-800 p-8 rounded-sm group relative overflow-hidden">
        <div class="absolute top-0 left-0 w-1 h-full bg-blue-600 opacity-0 group-hover:opacity-100 transition-opacity"></div>
        <p class="text-[10px] font-bold uppercase tracking-[0.3em] text-slate-500 mb-6 italic">Distance Array _ Beta</p>
        <div class="flex items-baseline gap-4">
            <span id="dist-2" class="text-8xl font-light text-white tracking-tighter">0.00</span>
            <span class="text-xl font-bold text-slate-700">MM</span>
        </div>
    </div>

    <div class="bg-[#0a0f1a] border border-slate-800 p-6 flex flex-col justify-between min-h-[200px]">
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Temp (°C)</p>
        <span id="temp" class="text-5xl font-bold text-white tracking-tight">--</span>
    </div>

    <div class="bg-[#0a0f1a] border border-slate-800 p-6 flex flex-col justify-between min-h-[200px]">
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Humidity (%)</p>
        <span id="hum" class="text-5xl font-bold text-white tracking-tight">--</span>
    </div>

    <div id="aqi-card" class="bg-[#0a0f1a] border border-slate-800 p-6 flex flex-col justify-between min-h-[200px] transition-colors">
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">AQI Index</p>
        <div>
            <span id="aqi" class="text-5xl font-bold text-white tracking-tight">--</span>
            <p id="aqi-desc" class="text-[9px] font-black uppercase mt-2 text-slate-700">Monitoring...</p>
        </div>
    </div>

    <div class="bg-[#0a0f1a] border border-slate-800 p-6 flex flex-col justify-between min-h-[200px]">
        <p class="text-[10px] font-bold uppercase tracking-widest text-slate-600">Barometer (hPa)</p>
        <span id="baro" class="text-5xl font-bold text-white tracking-tight">--</span>
    </div>

  </main>

  <script>
    import { db, auth } from "../lib/firebase";
    import { onAuthStateChanged, signOut } from "firebase/auth";
    import { ref, onValue } from "firebase/database";

    // 1. Auth Guard
    onAuthStateChanged(auth, (user) => {
        if (!user) window.location.href = "/login";
        else startStream();
    });

    document.getElementById('logout')?.addEventListener('click', () => signOut(auth));

    // 2. Data Fetching
    function startStream() {
        const syncStatus = document.getElementById('sync-status');
        const sensorRef = ref(db, 'sensor'); // Assuming the path from your screenshot

        onValue(sensorRef, (snapshot) => {
            const data = snapshot.val();
            if (!data) return;

            // Update Connection Badge
            if (syncStatus) {
                syncStatus.innerHTML = `<span class="h-1.5 w-1.5 bg-cyan-500 rounded-full animate-pulse shadow-[0_0_8px_cyan]"></span> Live`;
                syncStatus.classList.add('border-cyan-500/30', 'text-cyan-500');
            }

            // Update UI
            const update = (id, val, fixed = 1) => {
                const el = document.getElementById(id);
                if (el) el.innerText = typeof val === 'number' ? val.toFixed(fixed) : val;
            };

            update('dist-1', data.distance, 2);
            update('dist-2', data.distance_2 || 0, 2);
            update('temp', data.temp || 0, 1);
            update('hum', data.humidity || 0, 0);
            update('aqi', data.aqi || 0, 0);
            update('baro', data.barometer || 0, 1);

            // AQI Logic
            const aqiCard = document.getElementById('aqi-card');
            const aqiDesc = document.getElementById('aqi-desc');
            const aqi = data.aqi || 0;
            if (aqiCard && aqiDesc) {
                if (aqi < 50) { aqiDesc.innerText = "Optimal"; aqiCard.style.borderColor = "#06b6d433"; }
                else { aqiDesc.innerText = "Warning"; aqiCard.style.borderColor = "#f59e0b33"; }
            }
        });
    }
  </script>
</body>
</html>