---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';
import GasGauge from '../components/GasGauge.astro';
import SpatialMap from '../components/SpatialMap.astro';
import Sidebar from '../components/Sidebar.astro';
---

<Layout title="ARK | Command Center">
  <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js" is:inline></script>

  <div id="notification-center" class="fixed top-6 left-1/2 -translate-x-1/2 z-[9999] w-full max-w-xs space-y-2 pointer-events-none"></div>

  <div class="relative min-h-screen w-full py-8">
    <main id="dashboard-main" class="max-w-7xl mx-auto grid grid-cols-1 lg:grid-cols-12 gap-8 opacity-0 translate-y-4 transition-all duration-1000">
      
      <div class="lg:col-span-4 space-y-8">
        <GlassCard title="Hardware Pulse">
          <div class="flex justify-between items-end">
            <h2 id="hw-time" class="text-5xl font-light text-slate-950 tracking-tight tabular-nums">--:--:--</h2>
            <div class="pb-2">
                <p id="display-uuid" class="text-[10px] font-black text-orange-600 uppercase tracking-widest italic">Node: ---</p>
            </div>
          </div>
          <button id="enable-notifs" class="mt-4 text-[9px] font-black uppercase tracking-widest text-slate-400 hover:text-orange-500 transition-colors">
            • Enable Browser Alerts
          </button>
        </GlassCard>

        <GlassCard title="Air Analysis">
          <GasGauge />
        </GlassCard>

        <div class="grid grid-cols-2 gap-4">
          <div class="glass-surface p-7 rounded-[40px]">
            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest leading-none">Ambient Temp</p>
            <h4 id="val-temp" class="text-3xl font-bold text-slate-950 mt-2 italic tracking-tighter">--°F</h4>
          </div>
          <div class="glass-surface p-7 rounded-[40px]">
            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest leading-none">Humidity</p>
            <h4 id="val-hum" class="text-3xl font-bold text-slate-950 mt-2 italic tracking-tighter">--%</h4>
          </div>
          <div class="glass-surface p-7 rounded-[40px] col-span-2">
            <p class="text-[9px] font-bold text-slate-400 uppercase tracking-widest leading-none">Barometric Pressure</p>
            <h4 id="val-press" class="text-3xl font-bold text-slate-950 mt-2 italic tracking-tighter">-- hPa</h4>
          </div>
        </div>
      </div>

      <div class="lg:col-span-8 space-y-8">
        <SpatialMap />
        <GlassCard title="Atmospheric Evolution">
           <div class="h-56 md:h-64"><canvas id="tempChart"></canvas></div>
        </GlassCard>
      </div>
    </main>
  </div>

  <script>
    import { auth, db } from "../lib/firebase";
    import { ref, onValue, get } from "firebase/database";
    import L from 'leaflet';

    let map: any, marker: any, tempChart: any;
    let lastLidState: string | null = null;
    let lastTemp: number | null = null;
    const HOUSTON = [29.7604, -95.3698];

    // --- NOTIFICATION SYSTEM ---
    async function requestNotifPermission() {
      if ("Notification" in window) {
        const permission = await Notification.requestPermission();
        if (permission === "granted") {
          sendNotification("System", "Browser notifications enabled.");
        }
      }
    }

    function sendNotification(title: string, message: string) {
      // 1. Internal UI Toast
      const hub = document.getElementById('notification-center');
      if (hub) {
        const toast = document.createElement('div');
        toast.className = `glass-surface !bg-white/95 p-3 !rounded-2xl shadow-xl flex items-center gap-3 border-l-4 border-l-orange-500 translate-y-[-10px] opacity-0 transition-all duration-300 pointer-events-auto`;
        toast.innerHTML = `<div class="w-8 h-8 bg-orange-500 rounded-lg flex-shrink-0 flex items-center justify-center text-white"><svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" stroke-width="2.5"/></svg></div><div><p class="text-[10px] font-bold text-slate-900 leading-tight">${message}</p></div>`;
        hub.appendChild(toast);
        setTimeout(() => toast.classList.remove('translate-y-[-10px]', 'opacity-0'), 10);
        setTimeout(() => { toast.classList.add('opacity-0'); setTimeout(() => toast.remove(), 500); }, 4000);
      }

      // 2. Native Browser Notification (If window minimized)
      if (document.hidden && Notification.permission === "granted") {
        new Notification(title, { body: message, icon: "/favicon.svg" });
      }
    }

    document.getElementById('enable-notifs')?.addEventListener('click', requestNotifPermission);

    // --- DATA STREAM ---
    function initEngines() {
      const ctx = document.getElementById('tempChart') as HTMLCanvasElement;
      tempChart = new Chart(ctx, {
          type: 'line',
          data: { labels: [], datasets: [{ data: [], borderColor: '#F97316', borderWidth: 4, tension: 0.4, fill: false, pointRadius: 0 }] },
          options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { display: false }, y: { grid: { display: false }, ticks: { font: { size: 10, weight: '900' }, color: '#94a3b8' } } } }
      });

      map = L.map('map', { zoomControl: false, attributionControl: false }).setView(HOUSTON, 12);
      L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_nolabels/{z}/{x}/{y}{r}.png').addTo(map);
      const orangeIcon = L.divIcon({ className: 'ark-position-marker', iconSize: [14, 14], iconAnchor: [7, 7] });
      marker = L.marker(HOUSTON, { icon: orangeIcon }).addTo(map);
    }

    auth.onAuthStateChanged(async (user) => {
        if (!user) return;
        const snap = await get(ref(db, `software/users/${user.uid}/linkedDevice`));
        if (snap.exists()) {
            initEngines();
            const id = snap.val();
            document.getElementById('display-uuid')!.innerText = `Node: ${id}`;
            document.getElementById('dashboard-main')!.classList.remove('opacity-0', 'translate-y-4');
            startStream(id);
        }
    });

    function startStream(id: string) {
        onValue(ref(db, `hardware/${id}`), (snapshot) => {
            const data = snapshot.val();
            if (!data) return;

            if (data.environment) {
                const f = (data.environment.temp * 1.8) + 32;
                document.getElementById('val-temp')!.innerText = `${f.toFixed(1)}°F`;
                document.getElementById('val-hum')!.innerText = `${Math.round(data.environment.humidity)}%`;
                document.getElementById('val-press')!.innerText = `${data.environment.pressure} hPa`;

                // Sync Mini Sidebar
                const sT = document.getElementById('side-temp');
                const sH = document.getElementById('side-hum');
                if(sT) sT.innerText = `${Math.round(f)}°`;
                if(sH) sH.innerText = `${Math.round(data.environment.humidity)}%`;
                
                if (lastTemp !== null && Math.abs(f - lastTemp) > 3.0) {
                  sendNotification("Climate Alert", "Rapid temperature spike detected.");
                }
                lastTemp = f;

                if (tempChart.data.labels.length > 25) { 
                  tempChart.data.labels.shift(); 
                  tempChart.data.datasets[0].data.shift(); 
                }
                tempChart.data.labels.push(""); 
                tempChart.data.datasets[0].data.push(f);
                tempChart.update('none');
            }

            const d1 = data.motion?.sensor_1_cm || 0;
            const currentState = d1 > 12 ? 'open' : 'closed';
            if (lastLidState !== null && currentState !== lastLidState) {
              sendNotification("Security Hub", currentState === 'open' ? "Perimeter Breached" : "Perimeter Secured");
            }
            lastLidState = currentState;

            const hasGPS = data.gps && data.gps.lat !== 0 && data.gps.status !== "searching";
            const targetPos = hasGPS ? [data.gps.lat, data.gps.lng] : HOUSTON;
            marker.setLatLng(targetPos);
            map.panTo(targetPos);

            const locText = document.getElementById('geo-location-text');
            if (locText) locText.innerText = hasGPS ? `${data.gps.lat.toFixed(4)}, ${data.gps.lng.toFixed(4)}` : "Houston, TX (Searching...)";
            
            document.getElementById('hw-time')!.innerText = data.last_seen || "--:--:--";
        });
    }
  </script>
</Layout>