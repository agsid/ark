---
import Layout from '../layouts/Layout.astro';
import GlassCard from '../components/GlassCard.astro';
---

<Layout title="Link Device | ARK">
  <main class="relative min-h-screen flex items-center justify-center p-6 overflow-hidden">
    <div class="absolute inset-0 z-0">
        <div class="absolute top-1/4 left-1/3 w-96 h-96 bg-orange-500/10 blur-[120px] rounded-full animate-pulse"></div>
        <div class="absolute bottom-1/3 right-1/4 w-64 h-64 bg-indigo-500/10 blur-[100px] rounded-full"></div>
    </div>

    <div class="relative z-10 w-full max-w-md">
      <GlassCard class="!p-10 flex flex-col items-center text-center shadow-2xl">
        <div class="w-16 h-16 bg-slate-950 rounded-[24px] flex items-center justify-center text-orange-500 mb-8 shadow-xl">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                <path d="M12 4v1m0 14v1m8-8h-1m-14 0h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
            </svg>
        </div>

        <h1 class="text-2xl font-bold text-slate-900 tracking-tighter mb-2">Hardware Handshake</h1>
        <p class="text-[10px] font-black text-slate-400 uppercase tracking-widest mb-10">Enter UUID to bind software to hardware</p>

        <div class="w-full space-y-4">
          <input 
            type="text" 
            id="uuid-input" 
            placeholder="DEVICE UUID" 
            class="w-full bg-slate-100/50 border border-white rounded-2xl px-6 py-4 text-center font-mono font-bold tracking-[0.3em] outline-none focus:ring-4 focus:ring-orange-500/10 transition-all"
          />
          <button 
            id="link-btn" 
            class="w-full bg-orange-500 text-white py-4 rounded-2xl text-[10px] font-black uppercase tracking-widest hover:bg-slate-900 transition-all active:scale-95 shadow-lg shadow-orange-200"
          >
            Initialize Link
          </button>
        </div>
      </GlassCard>
      
      <p class="text-center mt-8">
        <a href="/" class="text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-orange-500 transition-colors">← Back to Terminal</a>
      </p>
    </div>
  </main>

  <script>
    import { auth, db } from "../lib/firebase";
    import { ref, set } from "firebase/database";

    const btn = document.getElementById('link-btn');
    const input = document.getElementById('uuid-input') as HTMLInputElement;

    btn?.addEventListener('click', async () => {
        const uuid = input.value.trim();
        const user = auth.currentUser;

        if (uuid && user) {
            // Save link in the software/users node
            await set(ref(db, `software/users/${user.uid}/linkedDevice`), uuid);
            window.location.href = "/"; // Go to dashboard
        } else if (!user) {
            alert("Please sign in first");
        }
    });
  </script>
</Layout>