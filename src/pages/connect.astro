---
import DashboardLayout from '../layouts/DashboardLayout.astro';
---

<DashboardLayout title="ARK | Link Hardware">
  <div class="max-w-md mx-auto pt-20 px-4">
    <div class="text-center mb-10">
      <h1 class="text-2xl font-bold text-slate-900 tracking-tight">Link Hardware</h1>
      <p class="text-slate-500 text-sm mt-2">Enter the device serial number to link it to your account.</p>
    </div>

    <div class="bg-white border border-slate-200 rounded-[32px] shadow-sm p-8">
      <form id="connect-form" class="space-y-6">
        <div class="space-y-2">
          <label for="deviceId" class="text-[10px] font-bold uppercase tracking-widest text-slate-400 ml-4">
            Serial Number
          </label>
          <input 
            type="text" 
            id="deviceId" 
            name="deviceId"
            placeholder="ARK-000000" 
            required
            class="w-full h-14 px-6 bg-slate-50 border border-slate-200 rounded-2xl text-slate-900 font-mono text-sm focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 outline-none transition-all"
          />
        </div>

        <button 
          type="submit" 
          id="submit-btn"
          class="w-full h-14 bg-slate-900 hover:bg-orange-600 text-white font-bold rounded-2xl transition-all flex items-center justify-center gap-3"
        >
          <span id="btn-text">Connect Device</span>
        </button>
      </form>

      <div id="status-container" class="hidden mt-6 p-4 rounded-xl text-center text-[11px] font-bold border">
      </div>
    </div>

    <p class="text-center mt-8 text-[11px] text-slate-400">
      Contact <a href="mailto:support@allied.com" class="text-orange-600 font-bold hover:underline">Support</a> if you cannot find your ID.
    </p>
  </div>
</DashboardLayout>

<script>
  import { db, auth } from "../lib/firebase";
  import { ref, update, get } from "firebase/database";

  const form = document.getElementById('connect-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const btnText = document.getElementById('btn-text');
  const statusContainer = document.getElementById('status-container');
  const deviceInput = document.getElementById('deviceId') as HTMLInputElement;

  function showStatus(msg: string, isError: boolean) {
    if (!statusContainer) return;
    statusContainer.classList.remove('hidden');
    statusContainer.textContent = msg;
    statusContainer.className = isError 
      ? "mt-6 p-4 rounded-xl text-center text-[11px] font-bold bg-red-50 text-red-700 border-red-100"
      : "mt-6 p-4 rounded-xl text-center text-[11px] font-bold bg-green-50 text-green-700 border-green-100";
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fullId = deviceInput.value.trim().toUpperCase();
    const user = auth.currentUser;

    if (!user) {
        showStatus("Session expired. Please log in again.", true);
        return;
    }

    if (!fullId.startsWith('ARK-')) {
      showStatus("Invalid format. Use ARK-XXXXXX", true);
      return;
    }

    const numericId = fullId.replace('ARK-', '');

    // UI Loading
    submitBtn.disabled = true;
    if (btnText) btnText.textContent = "Connecting...";

    try {
      // 1. Verify if the hardware node exists in the DB
      const nodeRef = ref(db, `hardware/${numericId}`);
      const nodeSnap = await get(nodeRef);

      if (!nodeSnap.exists()) {
        showStatus("Device ID not found in registry.", true);
        submitBtn.disabled = false;
        if (btnText) btnText.textContent = "Connect Device";
        return;
      }

      // 2. Link device to the user profile
      const userRef = ref(db, `software/user/${user.uid}`);
      await update(userRef, {
        linked_device: numericId,
        last_sync: new Date().toISOString()
      });

      // 3. Success state
      localStorage.setItem('ark_linked_node', numericId);
      showStatus(`Linked to ${fullId}. Redirecting...`, false);

      setTimeout(() => {
        window.location.href = '/';
      }, 1500);

    } catch (err: any) {
      showStatus(`Error: ${err.message}`, true);
      submitBtn.disabled = false;
      if (btnText) btnText.textContent = "Connect Device";
    }
  });

  // Auto-format input to include prefix
  deviceInput?.addEventListener('input', () => {
    let val = deviceInput.value.toUpperCase();
    if (val.length > 0 && !val.startsWith('ARK-')) {
      deviceInput.value = 'ARK-' + val;
    }
  });
</script>