---
import '../styles/global.css';
---

<html lang="en">
<head>
    <title>Authorize | ARK Vault</title>
</head>
<body class="min-h-screen flex items-center justify-center p-6">
    <div class="fixed top-20 left-20 w-32 h-32 bg-indigo-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob"></div>
    <div class="fixed bottom-20 right-20 w-32 h-32 bg-cyan-200 rounded-full mix-blend-multiply filter blur-xl opacity-70 animate-blob animation-delay-2000"></div>

    <div class="w-full max-w-[400px] glass rounded-3xl p-8 md:p-10 floating relative z-10">
        <div class="text-center mb-8">
            <div class="w-16 h-16 bg-indigo-600 rounded-2xl shadow-xl shadow-indigo-200 mx-auto flex items-center justify-center text-white text-2xl font-bold mb-4 transform -rotate-6">A</div>
            <h1 class="text-2xl font-black text-slate-900 tracking-tight">ARK <span class="text-indigo-600">VAULT</span></h1>
            <p class="text-slate-500 text-sm mt-1">Enterprise Asset Management</p>
        </div>

        <div class="space-y-4">
            <button id="google-login" class="w-full flex items-center justify-center gap-3 bg-white border border-slate-200 py-3 rounded-xl text-sm font-semibold text-slate-700 hover:bg-slate-50 hover:shadow-md transition-all active:scale-95">
                <img src="https://www.gstatic.com/firebasejs/ui/2.0.0/images/pwa_rebrand/google.svg" class="w-5 h-5" />
                Sign in with Google
            </button>

            <div class="flex items-center gap-4 py-2">
                <div class="h-[1px] w-full bg-slate-200"></div>
                <span class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">OR</span>
                <div class="h-[1px] w-full bg-slate-200"></div>
            </div>

            <form id="email-form" class="space-y-3">
                <input type="email" id="email" placeholder="Email Address" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all text-sm" />
                <input type="password" id="password" placeholder="Password" class="w-full px-4 py-3 rounded-xl border border-slate-200 focus:border-indigo-500 focus:ring-4 focus:ring-indigo-500/10 outline-none transition-all text-sm" />
                <button class="w-full bg-slate-900 text-white py-3 rounded-xl text-sm font-bold hover:bg-indigo-600 shadow-lg shadow-indigo-100 transition-all active:scale-95">
                    Authorize Session
                </button>
            </form>
        </div>

        <p id="status" class="text-center mt-6 text-xs font-medium text-slate-400 min-h-[1em]"></p>
    </div>

    <script>
        import { auth } from "../lib/firebase";
        import { GoogleAuthProvider, signInWithPopup, signInWithEmailAndPassword } from "firebase/auth";

        const googleBtn = document.getElementById('google-login');
        const emailForm = document.getElementById('email-form');
        const status = document.getElementById('status');

        // GOOGLE: This is where the profile pic comes from
        googleBtn?.addEventListener('click', async () => {
            const provider = new GoogleAuthProvider();
            try {
                // Forces Google to show the account picker (helpful for switching accounts)
                provider.setCustomParameters({ prompt: 'select_account' });
                await signInWithPopup(auth, provider);
                window.location.href = "/";
            } catch (e: any) {
                status!.innerText = "Authentication Failed.";
            }
        });

        // EMAIL
        emailForm?.addEventListener('submit', async (e) => {
            e.preventDefault();
            const email = (document.getElementById('email') as HTMLInputElement).value;
            const pass = (document.getElementById('password') as HTMLInputElement).value;
            try {
                await signInWithEmailAndPassword(auth, email, pass);
                window.location.href = "/";
            } catch (e: any) {
                status!.innerText = "Invalid credentials.";
            }
        });
    </script>
</body>
</html>