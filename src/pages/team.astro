---
import Layout from '../layouts/Layout.astro';
---

<Layout title="ARK | Team Setup">
    <div class="min-h-[calc(100vh-64px)] flex items-center justify-center p-6 bg-slate-50">
        <div class="w-full max-w-5xl">
            <div class="text-center mb-12">
                <h1 class="text-4xl font-light tracking-tight text-slate-900">
                    Protocol <span class="font-semibold text-orange-600">Initialization</span>
                </h1>
                <p class="text-slate-500 mt-2">Establish a new workspace or join an existing secure team.</p>
            </div>

            <div class="grid md:grid-cols-2 gap-8">
                <div class="bg-white p-10 rounded-[40px] border border-slate-100 shadow-xl shadow-slate-200/50 flex flex-col justify-between group transition-all hover:border-orange-200">
                    <div>
                        <div class="w-14 h-14 bg-orange-100 text-orange-600 rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:rotate-3 transition-transform">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 6v6m0 0v6m0-6h6m-6 0H6" />
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-slate-900 mb-4">Start New Team</h2>
                        <p class="text-slate-500 text-sm leading-relaxed mb-8">
                            Create a fresh workspace. You'll receive a unique 8-digit ID to share with your teammates.
                        </p>
                    </div>

                    <div class="space-y-4">
                        <input type="text" id="create-team-name" placeholder="Team Name (e.g. Lab Alpha)" 
                            class="w-full p-4 rounded-2xl bg-slate-50 border border-slate-100 outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500/50 transition-all" />
                        <button id="btn-create" class="w-full py-4 bg-slate-900 text-white font-bold rounded-2xl hover:bg-slate-800 transition-all active:scale-[0.98] shadow-lg shadow-slate-200 uppercase text-[11px] tracking-widest">
                            Generate Workspace
                        </button>
                    </div>
                </div>

                <div class="bg-white p-10 rounded-[40px] border border-slate-100 shadow-xl shadow-slate-200/50 flex flex-col justify-between group transition-all hover:border-orange-200">
                    <div>
                        <div class="w-14 h-14 bg-orange-600 text-white rounded-2xl flex items-center justify-center mb-8 group-hover:scale-110 group-hover:-rotate-3 transition-transform shadow-lg shadow-orange-600/20">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z" />
                            </svg>
                        </div>
                        <h2 class="text-2xl font-bold text-slate-900 mb-4">Join via ID</h2>
                        <p class="text-slate-500 text-sm leading-relaxed mb-8">
                            Enter the unique 8-digit access code provided by your team administrator.
                        </p>
                    </div>

                    <div class="space-y-4">
                        <input type="text" id="join-team-id" maxlength="8" placeholder="8-DIGIT CODE" 
                            class="w-full p-4 rounded-2xl bg-slate-50 border border-slate-100 outline-none focus:ring-4 focus:ring-orange-500/10 focus:border-orange-500/50 transition-all text-center font-mono text-xl font-bold tracking-[0.3em] uppercase placeholder:tracking-normal placeholder:font-sans placeholder:text-sm" />
                        <button id="btn-join" class="w-full py-4 bg-orange-600 text-white font-bold rounded-2xl hover:bg-orange-700 transition-all active:scale-[0.98] shadow-xl shadow-orange-600/20 uppercase text-[11px] tracking-widest">
                            Sync to Team
                        </button>
                    </div>
                </div>
            </div>

            <div id="teamMessageBox" class="mt-8 p-4 rounded-2xl text-[12px] font-medium hidden border text-center max-w-md mx-auto"></div>
        </div>
    </div>

    <script>
        import { auth, db } from "../lib/firebase";
        import { doc, setDoc, updateDoc, arrayUnion, getDoc } from "firebase/firestore";

        const btnCreate = document.getElementById('btn-create');
        const btnJoin = document.getElementById('btn-join');
        const msgBox = document.getElementById('teamMessageBox');

        function showMsg(text: string, isError: boolean) {
            if (!msgBox) return;
            msgBox.textContent = text;
            msgBox.className = `mt-8 p-4 rounded-2xl text-[12px] font-medium border text-center max-w-md mx-auto ${
                isError ? 'bg-red-50 text-red-700 border-red-100' : 'bg-orange-50 text-orange-700 border-orange-100'
            }`;
            msgBox.classList.remove('hidden');
        }

        // --- Generate 8-Digit ID ---
        function generateID() {
            return Math.random().toString(36).substring(2, 10).toUpperCase();
        }

        // --- CREATE TEAM LOGIC ---
        btnCreate?.addEventListener('click', async () => {
            const teamName = (document.getElementById('create-team-name') as HTMLInputElement).value;
            const user = auth.currentUser;

            if (!teamName) return showMsg("Please enter a team name", true);
            if (!user) return showMsg("Session expired. Please login again.", true);

            try {
                const teamId = generateID();
                
                // 1. Create Team Document
                await setDoc(doc(db, "teams", teamId), {
                    name: teamName,
                    admin: user.uid,
                    members: [user.uid],
                    createdAt: new Date()
                });

                // 2. Link User to Team
                await updateDoc(doc(db, "users", user.uid), {
                    teamId: teamId
                });

                showMsg(`Team Created! ID: ${teamId}. Redirecting...`, false);
                setTimeout(() => window.location.href = '/', 2000);
            } catch (e: any) {
                showMsg(e.message, true);
            }
        });

        // --- JOIN TEAM LOGIC ---
        btnJoin?.addEventListener('click', async () => {
            const teamIdInput = (document.getElementById('join-team-id') as HTMLInputElement).value.toUpperCase();
            const user = auth.currentUser;

            if (teamIdInput.length !== 8) return showMsg("ID must be exactly 8 characters", true);
            if (!user) return showMsg("Session expired", true);

            try {
                const teamRef = doc(db, "teams", teamIdInput);
                const teamSnap = await getDoc(teamRef);

                if (!teamSnap.exists()) {
                    return showMsg("Invalid Team ID. Check with your admin.", true);
                }

                // 1. Add user to Team's member array
                await updateDoc(teamRef, {
                    members: arrayUnion(user.uid)
                });

                // 2. Link User profile to this Team
                await updateDoc(doc(db, "users", user.uid), {
                    teamId: teamIdInput
                });

                showMsg("Successfully synced! Redirecting...", false);
                setTimeout(() => window.location.href = '/', 1500);
            } catch (e: any) {
                showMsg(e.message, true);
            }
        });
    </script>
</Layout>