---
import Layout from '../layouts/Layout.astro';
import '../styles/global.css';
---

<Layout title="ARK | Secure Portal">
  <div class="min-h-[100dvh] w-full flex items-center justify-center bg-[#050505] p-5 sm:p-8 overflow-hidden relative">
    
    <div class="absolute top-[-10%] right-[-10%] w-[300px] h-[300px] bg-indigo-600/20 rounded-full blur-[100px] -z-10"></div>
    <div class="absolute bottom-[-10%] left-[-10%] w-[300px] h-[300px] bg-blue-600/10 rounded-full blur-[100px] -z-10"></div>

    <div class="w-full max-w-[400px] flex flex-col gap-6">
      
      <div class="text-center select-none mb-2">
        <div class="w-14 h-14 bg-indigo-600 rounded-[20px] shadow-lg shadow-indigo-900/40 mx-auto flex items-center justify-center text-white text-2xl font-black mb-4">
          A
        </div>
        <h1 class="text-3xl font-black italic tracking-tighter text-white uppercase leading-none" id="auth-title">
          ARK<span class="text-indigo-500">.</span>VAULT
        </h1>
        <p class="text-[9px] font-bold text-zinc-500 uppercase tracking-[0.4em] mt-2" id="auth-subtitle">
          Allied Relic Keeper
        </p>
      </div>

      <div id="auth-card" class="glass-panel rounded-[2.5rem] p-7 sm:p-10 border border-white/10 relative transition-all duration-500">
        
        <button id="googleBtn" class="w-full py-4 flex items-center justify-center gap-3 bg-white/5 border border-white/10 rounded-2xl text-sm font-bold text-white active:scale-95 transition-all shadow-sm mb-6">
          <img src="https://www.svgrepo.com/show/475656/google-color.svg" class="w-5 h-5" />
          Continue with Google
        </button>

        <div class="flex items-center mb-6 opacity-20">
          <div class="flex-grow h-px bg-white"></div>
          <span class="mx-3 text-[10px] font-black text-white uppercase">OR</span>
          <div class="flex-grow h-px bg-white"></div>
        </div>

        <form id="auth-form" class="flex flex-col gap-3.5">
          <div id="name-container" class="hidden">
            <input name="name" type="text" placeholder="Full Name" class="auth-input" />
          </div>
          
          <input name="email" type="email" placeholder="Email Address" required class="auth-input" />
          
          <input name="password" type="password" placeholder="Passkey" required class="auth-input" />

          <div id="confirm-container" class="hidden">
            <input name="confirm" type="password" placeholder="Confirm Passkey" class="auth-input" />
          </div>

          <button type="submit" id="submit-btn" class="mt-4 py-4 rounded-2xl bg-indigo-600 text-white text-[11px] font-black uppercase tracking-widest hover:bg-indigo-500 active:scale-[0.97] transition-all shadow-lg shadow-indigo-900/20">
            Initialize Access
          </button>
        </form>

        <p class="text-center mt-8 text-zinc-500 text-[11px] font-medium uppercase tracking-tight">
          <span id="toggle-label">New to the vault?</span>
          <button id="toggle-mode" class="text-indigo-400 font-bold hover:underline ml-1">Create Account</button>
        </p>
      </div>

      <p id="msg" class="text-center text-[9px] font-black uppercase tracking-widest min-h-[12px] h-3"></p>
    </div>
  </div>
</Layout>

<style is:global>
  .glass-panel {
    background: rgba(255, 255, 255, 0.03);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  /* Fixed Mobile Input Size (16px prevents iOS zoom) */
  .auth-input {
    width: 100%;
    background: rgba(0, 0, 0, 0.3);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 1rem;
    padding: 1.1rem 1.25rem;
    color: white;
    font-size: 16px !important; 
    transition: all 0.3s;
    outline: none;
  }

  .auth-input:focus {
    border-color: rgba(99, 102, 241, 0.5);
    background: rgba(255, 255, 255, 0.05);
    box-shadow: 0 0 20px rgba(99, 102, 241, 0.1);
  }

  .auth-input::placeholder {
    color: #3f3f46;
  }
</style>

<script>
  import { auth } from "../lib/firebase";
  import { 
    signInWithEmailAndPassword, 
    createUserWithEmailAndPassword, 
    GoogleAuthProvider, 
    signInWithPopup 
  } from "firebase/auth";

  let mode = "signin";

  const form = document.getElementById('auth-form');
  const toggleBtn = document.getElementById('toggle-mode');
  const toggleLabel = document.getElementById('toggle-label');
  const submitBtn = document.getElementById('submit-btn');
  const nameContainer = document.getElementById('name-container');
  const confirmContainer = document.getElementById('confirm-container');
  const msg = document.getElementById('msg');

  // Toggle Functionality
  toggleBtn.addEventListener('click', () => {
    mode = mode === "signin" ? "signup" : "signin";
    
    nameContainer.classList.toggle('hidden', mode === "signin");
    confirmContainer.classList.toggle('hidden', mode === "signin");
    
    toggleLabel.innerText = mode === "signin" ? "New to the vault?" : "Already a member?";
    toggleBtn.innerText = mode === "signin" ? "Create Account" : "Sign In";
    submitBtn.innerText = mode === "signin" ? "Initialize Access" : "Create Identity";
  });

  // Handle Auth
  form.addEventListener('submit', async (e) => {
    e.preventDefault();
    const fd = new FormData(form);
    const email = fd.get("email");
    const password = fd.get("password");
    const confirm = fd.get("confirm");

    try {
      if (mode === "signup") {
        if (password !== confirm) throw new Error("Passkeys do not match");
        await createUserWithEmailAndPassword(auth, email, password);
      } else {
        await signInWithEmailAndPassword(auth, email, password);
      }
      window.location.href = "/dashboard";
    } catch (err) {
      msg.innerText = err.message.replace('Firebase: ', '');
      msg.classList.add('text-red-500');
    }
  });

  // Google Provider logic
  document.getElementById('googleBtn').addEventListener('click', async () => {
    try {
      const provider = new GoogleAuthProvider();
      await signInWithPopup(auth, provider);
      window.location.href = "/dashboard";
    } catch (err) {
      msg.innerText = "Google Authentication Failed";
      msg.classList.add('text-red-500');
    }
  });
</script>