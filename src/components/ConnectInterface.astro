---
import GlassCard from './GlassCard.astro';
---

<div class="flex flex-col items-center justify-center min-h-[70vh] w-full max-w-lg mx-auto">
  <GlassCard class="w-full !p-12 text-center flex flex-col items-center border-orange-500/20 shadow-orange-500/5">
    <div class="relative mb-8">
      <div class="absolute inset-0 bg-orange-500 blur-2xl opacity-20 animate-pulse"></div>
      <div class="relative w-20 h-20 bg-slate-950 rounded-[30px] flex items-center justify-center text-orange-500 shadow-2xl">
        <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
          <path d="M12 4v1m0 14v1m8-8h-1m-14 0h-1m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 100 8 4 4 0 000-8z" />
        </svg>
      </div>
    </div>

    <h1 class="text-3xl font-bold text-slate-900 tracking-tighter mb-2">Establish Link</h1>
    <p class="text-xs font-bold text-slate-400 uppercase tracking-widest mb-10">Enter your Hardware UUID to sync spatial data</p>

    <div class="w-full space-y-4">
      <div class="relative">
        <input 
          type="text" 
          id="uuid-input" 
          placeholder="000000" 
          class="w-full bg-white/50 border border-slate-200 rounded-3xl px-8 py-5 text-2xl font-mono font-bold text-center tracking-[0.5em] outline-none focus:border-orange-500 focus:ring-4 focus:ring-orange-500/10 transition-all placeholder:text-slate-200"
        />
      </div>
      
      <button 
        id="link-btn" 
        class="w-full bg-slate-900 text-white py-5 rounded-3xl text-xs font-black uppercase tracking-[0.3em] hover:bg-orange-500 hover:shadow-2xl hover:shadow-orange-500/40 transition-all active:scale-95"
      >
        Initialize Handshake
      </button>
      
      <p id="error-msg" class="text-[10px] font-bold text-rose-500 uppercase tracking-widest h-4 opacity-0 transition-opacity"></p>
    </div>
  </GlassCard>

  <a href="/" class="mt-8 text-[10px] font-black text-slate-400 uppercase tracking-widest hover:text-slate-600 transition-colors">
    ← Return to Dashboard
  </a>
</div>

<script>
  import { auth, db } from "../lib/firebase";
  import { ref, set } from "firebase/database";

  const input = document.getElementById('uuid-input') as HTMLInputElement;
  const btn = document.getElementById('link-btn');
  const error = document.getElementById('error-msg');

  btn?.addEventListener('click', async () => {
    const uuid = input.value.trim();
    const user = auth.currentUser;

    if (!uuid) {
      showError("Please enter a valid UUID");
      return;
    }

    if (user) {
      try {
        btn.innerText = "Syncing...";
        await set(ref(db, `software/users/${user.uid}/linkedDevice`), uuid);
        window.location.href = "/"; // Redirect back to home
      } catch (e) {
        showError("Handshake Failed");
      }
    } else {
      showError("User Authentication Required");
    }
  });

  function showError(msg: string) {
    if (error) {
      error.innerText = msg;
      error.style.opacity = "1";
      setTimeout(() => { error.style.opacity = "0"; }, 3000);
    }
  }
</script>