---
---
<div class="relative flex flex-col items-center justify-center p-4">
  <div class="relative w-48 h-28 overflow-hidden">
    <svg class="w-full h-full" viewBox="0 0 100 50">
      <path
        d="M 10 45 A 40 40 0 0 1 90 45"
        fill="none"
        stroke="#e2e8f0"
        stroke-width="8"
        stroke-linecap="round"
      />
      <path
        id="gas-progress"
        d="M 10 45 A 40 40 0 0 1 90 45"
        fill="none"
        stroke="#F97316"
        stroke-width="8"
        stroke-linecap="round"
        stroke-dasharray="126"
        stroke-dashoffset="126"
        class="transition-all duration-1000 ease-out"
      />
    </svg>

    <div 
      id="gas-needle" 
      class="absolute bottom-0 left-1/2 w-1 h-12 bg-slate-950 origin-bottom -translate-x-1/2 transition-transform duration-1000 ease-out rounded-full"
      style="transform: translateX(-50%) rotate(-90deg);"
    >
      <div class="w-3 h-3 bg-slate-950 rounded-full absolute -bottom-1 -left-1 shadow-lg"></div>
    </div>
  </div>

  <div class="text-center mt-2">
    <h3 id="gas-value" class="text-2xl font-black text-slate-950 tabular-nums italic tracking-tighter">-- kΩ</h3>
    <p id="gas-status" class="text-[8px] font-black uppercase tracking-[0.3em] text-slate-400 mt-1">Analyzing VOCs</p>
  </div>
</div>

<script>
  // This helper will be called by your main index.astro stream
  window.updateGasGauge = (value: number) => {
    const progressPath = document.getElementById('gas-progress') as unknown as SVGPathElement;
    const needle = document.getElementById('gas-needle');
    const valueText = document.getElementById('gas-value');
    const statusText = document.getElementById('gas-status');

    if (!progressPath || !needle || !valueText || !statusText) return;

    // BME680 Gas resistance usually ranges from 50 to 500+ kOhm
    // We'll map 0-300kOhm to the gauge for visual impact
    const maxVal = 300;
    const percentage = Math.min(Math.max(value / maxVal, 0), 1);
    
    // SVG Dash offset: 126 is empty, 0 is full
    const offset = 126 - (126 * percentage);
    progressPath.style.strokeDashoffset = offset.toString();

    // Rotation: -90deg is start, 90deg is end
    const rotation = -90 + (180 * percentage);
    needle.style.transform = `translateX(-50%) rotate(${rotation}deg)`;

    // Update Text
    valueText.innerText = `${Math.round(value)} kΩ`;

    // Status Logic
    if (value > 150) {
      statusText.innerText = "Air Quality: Optimal";
      statusText.style.color = "#10b981"; // Emerald
    } else if (value > 50) {
      statusText.innerText = "Air Quality: Normal";
      statusText.style.color = "#94a3b8"; // Slate
    } else {
      statusText.innerText = "Air Quality: Warning";
      statusText.style.color = "#f97316"; // Orange
    }
  };
</script>