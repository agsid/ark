---
interface Props {
  id: string;
  title: string;
  subtitle: string;
  chartId: string;
  colorClass: string; // e.g., "indigo" or "cyan"
}

const { id, title, subtitle, chartId, colorClass } = Astro.params;
---
<div class="glass-surface p-8 rounded-[2.5rem] shadow-xl bg-white border border-white relative overflow-hidden">
    <div class="flex justify-between items-start mb-6">
        <div>
            <p class={`text-[10px] font-black text-${colorClass}-600 uppercase tracking-[0.2em] mb-1`}>{subtitle}</p>
            <h4 class="text-2xl font-black text-slate-900 tracking-tight">{title}</h4>
        </div>
        <div id={`badge-${id}`} class="px-4 py-1.5 rounded-full text-[11px] font-black uppercase bg-slate-100 text-slate-400">Syncing</div>
    </div>
    
    <div class="flex items-center gap-4 mb-6">
        <span id={`text-${id}-status`} class="text-5xl font-black text-slate-900 tracking-tighter">--</span>
        {id !== 'lid' && <span class="text-xs font-bold text-slate-300 uppercase">CM</span>}
    </div>

    <div class="h-20 w-full opacity-50">
        <canvas id={chartId}></canvas>
    </div>
</div>