---
// src/components/Header.astro
---
<header id="topbar" class="fixed top-3 left-[98px] right-[14px] h-[56px] bg-white rounded-full shadow-sm z-50 flex items-center justify-between px-6 border border-slate-100">
  <div class="flex items-center gap-1.5 text-[11px] font-mono text-slate-400">
    <span>hardware</span>
    <span class="text-slate-200">/</span>
    <span id="tb-node" class="text-slate-600 font-bold bg-slate-50 px-2 py-0.5 rounded border border-slate-100">NO-LINK</span>
    <span class="text-slate-200">/</span>
    <span id="tb-section" class="text-orange-600 font-medium lowercase italic">environment</span>
  </div>

  <div class="flex items-center gap-2">
    <div id="conn-pill" class="flex items-center gap-2 px-3 py-1 border border-slate-200 bg-slate-50 rounded-full text-[9px] font-bold text-slate-400 [&.live]:bg-green-50 [&.live]:text-green-600 [&.live]:border-green-200 transition-all">
      <span class="size-1.5 rounded-full bg-current animate-pulse"></span>
      <span id="conn-status">WAITING</span>
    </div>
    <div class="hidden md:flex items-center gap-1.5 px-3 py-1 border border-slate-200 bg-slate-50 rounded-full text-[9px] font-bold text-slate-400">
      <span id="tb-lastseen">--:--:--</span>
    </div>
  </div>
</header>

<script>
  window.setLive = (displayId) => {
    const nodeEl = document.getElementById('tb-node');
    const pill = document.getElementById('conn-pill');
    const statusTxt = document.getElementById('conn-status');
    if (nodeEl) nodeEl.textContent = displayId;
    if (pill) pill.classList.add('live');
    if (statusTxt) statusTxt.textContent = 'LIVE';
  };

  window.setLastSeen = (time) => {
    const lastSeenEl = document.getElementById('tb-lastseen');
    if (lastSeenEl) lastSeenEl.textContent = time;
  };

  const savedNode = localStorage.getItem('ark_linked_node');
  if (savedNode) {
    const nodeEl = document.getElementById('tb-node');
    if (nodeEl) nodeEl.textContent = `ARK-${savedNode}`;
  }
</script>