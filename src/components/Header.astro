---
---
<header class="h-16 border-b border-slate-200/60 bg-white/80 backdrop-blur-md sticky top-0 z-[60] flex items-center px-4 md:px-8">
  <div class="max-w-7xl mx-auto w-full flex justify-between items-center">
    <div class="flex items-center gap-3">
      <div class="w-9 h-9 bg-gradient-to-tr from-indigo-700 to-indigo-500 rounded-xl flex items-center justify-center text-white shadow-lg shadow-indigo-200/50 transform transition-transform hover:scale-105 cursor-pointer">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>
      <div class="flex flex-col">
        <h1 class="text-slate-900 font-extrabold tracking-tight text-lg leading-tight hidden sm:block uppercase">ARK</h1>
        <p class="text-[9px] font-bold text-indigo-600 uppercase tracking-[0.2em] leading-none hidden sm:block">Core Interface</p>
      </div>
    </div>

    <div class="flex items-center gap-4 pl-6 border-l border-slate-100">
      <div class="text-right hidden md:block">
        <p id="user-display" class="text-sm font-bold text-slate-800 leading-none">Connecting...</p>
        <p class="text-[10px] font-medium text-slate-400 mt-1 uppercase tracking-tighter">Authorized Operator</p>
      </div>
      
      <div class="relative group cursor-pointer" id="profile-menu-trigger">
        <img id="user-photo" referrerpolicy="no-referrer" src="https://ui-avatars.com/api/?name=U&background=f1f5f9&color=64748b" 
             class="w-10 h-10 rounded-xl border-2 border-white shadow-xl shadow-slate-200/50 object-cover ring-1 ring-slate-100 transition-transform active:scale-90" 
             alt="Profile" />
        <div class="absolute -bottom-1 -right-1 w-3.5 h-3.5 bg-emerald-500 border-2 border-white rounded-full"></div>

        <div id="profile-dropdown" class="absolute right-0 mt-3 w-48 bg-white border border-slate-200 rounded-2xl shadow-2xl shadow-slate-300/50 py-2 opacity-0 invisible translate-y-2 transition-all duration-200 z-50">
          <div class="px-4 py-2 border-b border-slate-50 mb-1">
              <p class="text-[10px] font-bold text-slate-400 uppercase tracking-widest">Account</p>
          </div>
          <button id="logout-action" class="w-full flex items-center gap-3 px-4 py-2.5 text-sm font-bold text-rose-500 hover:bg-rose-50 transition-colors">
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/>
            </svg>
            Sign Out
          </button>
        </div>
      </div>
    </div>
  </div>
</header>

<script>
  import { auth } from "../lib/firebase";
  import { signOut, onAuthStateChanged } from "firebase/auth";

  const dropdown = document.getElementById('profile-dropdown');
  const trigger = document.getElementById('profile-menu-trigger');
  const logoutBtn = document.getElementById('logout-action');
  const userDisplay = document.getElementById('user-display');
  const userPhoto = document.getElementById('user-photo') as HTMLImageElement;

  // UI Toggle
  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    dropdown?.classList.toggle('opacity-0');
    dropdown?.classList.toggle('invisible');
    dropdown?.classList.toggle('translate-y-2');
  });

  window.addEventListener('click', () => {
    dropdown?.classList.add('opacity-0', 'invisible', 'translate-y-2');
  });

  // Auth Logic
  onAuthStateChanged(auth, (user) => {
    if (user) {
      if (userDisplay) userDisplay.innerText = user.displayName || user.email?.split('@')[0] || "Operator";
      if (userPhoto && user.photoURL) userPhoto.src = user.photoURL;
    }
  });

  logoutBtn?.addEventListener('click', () => {
    signOut(auth).then(() => window.location.href = "/login");
  });
</script>