---
// src/components/Sidebar.astro
---
<nav 
  id="sidenav" 
  class="group fixed z-[60] bg-white/90 backdrop-blur-2xl transition-all duration-500 ease-[cubic-bezier(0.23,1,0.32,1)] border-slate-200/60
         /* Desktop: Floating Side Capsule */
         md:left-4 md:top-1/2 md:-translate-y-1/2 md:flex md:flex-col md:py-6 md:w-[80px] md:hover:w-[240px] md:rounded-[40px] md:h-[calc(100vh-100px)] md:border md:shadow-[0_20px_50px_rgba(0,0,0,0.1)]
         /* Phone: Bottom Tab Pill */
         max-md:bottom-0 max-md:left-0 max-md:w-full max-md:h-[calc(80px+env(safe-area-inset-bottom))] max-md:flex max-md:flex-row max-md:items-start max-md:justify-around max-md:px-4 max-md:pt-3 max-md:border-t max-md:rounded-t-[35px] max-md:shadow-[0_-10px_40px_rgba(0,0,0,0.08)]"
>
  <div class="hidden md:flex h-12 items-center px-6 gap-4 shrink-0 mb-8">
    <div class="size-9 shrink-0 bg-slate-900 rounded-2xl flex items-center justify-center shadow-lg shadow-slate-900/20">
      <div class="size-2 bg-white rounded-full animate-pulse"></div>
    </div>
    <span class="text-lg font-black tracking-tighter text-slate-900 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      ARK<span class="text-indigo-600">.</span>
    </span>
  </div>

  <div class="flex md:flex-col max-md:flex-row max-md:w-full max-md:justify-around max-md:items-center md:gap-2">
    
    <a href="#environment" class="n-item active group/item flex items-center gap-4 px-5 py-3 transition-all max-md:flex-col max-md:px-2 rounded-2xl md:mx-3 hover:bg-slate-50">
      <span class="size-11 shrink-0 flex items-center justify-center text-slate-400 group-[.active]:text-white group-[.active]:bg-slate-900 group-[.active]:rounded-2xl group-[.active]:shadow-lg group-[.active]:shadow-slate-900/20 transition-all duration-300">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
      </span>
      <span class="text-[10px] md:text-sm font-bold text-slate-500 group-[.active]:text-slate-900 md:opacity-0 md:group-hover:opacity-100 transition-all whitespace-nowrap tracking-tight">Environment</span>
    </a>

    <a href="#gps" class="n-item group/item flex items-center gap-4 px-5 py-3 transition-all max-md:flex-col max-md:px-2 rounded-2xl md:mx-3 hover:bg-slate-50">
      <span class="size-11 shrink-0 flex items-center justify-center text-slate-400 group-[.active]:text-white group-[.active]:bg-slate-900 group-[.active]:rounded-2xl transition-all duration-300">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
      </span>
      <span class="text-[10px] md:text-sm font-bold text-slate-500 group-[.active]:text-slate-900 md:opacity-0 md:group-hover:opacity-100 transition-all whitespace-nowrap tracking-tight">GPS</span>
    </a>

    <a href="#motion" class="n-item group/item flex items-center gap-4 px-5 py-3 transition-all max-md:flex-col max-md:px-2 rounded-2xl md:mx-3 hover:bg-slate-50">
      <span class="size-11 shrink-0 flex items-center justify-center text-slate-400 group-[.active]:text-white group-[.active]:bg-slate-900 group-[.active]:rounded-2xl transition-all duration-300">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </span>
      <span class="text-[10px] md:text-sm font-bold text-slate-500 group-[.active]:text-slate-900 md:opacity-0 md:group-hover:opacity-100 transition-all whitespace-nowrap tracking-tight">Motion</span>
    </a>

    <a href="/connect" class="md:hidden flex flex-col items-center px-2">
      <span class="size-11 shrink-0 flex items-center justify-center text-slate-400">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M9 17.05a7 7 0 0 1 6 0"/><path d="M12 20h.01"/></svg>
      </span>
      <span class="text-[10px] font-bold text-slate-500">Connect</span>
    </a>
  </div>

  <div class="hidden md:flex flex-1"></div>

  <div class="hidden md:flex px-4 mb-4">
    <a href="/connect" class="flex items-center gap-4 px-2.5 py-2.5 w-full bg-indigo-600 hover:bg-indigo-700 text-white rounded-[22px] transition-all shadow-lg shadow-indigo-600/20 active:scale-[0.97]">
      <span class="size-10 shrink-0 flex items-center justify-center bg-white/20 rounded-xl">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M9 17.05a7 7 0 0 1 6 0"/><path d="M12 20h.01"/></svg>
      </span>
      <span class="text-xs font-black tracking-tight opacity-0 group-hover:opacity-100 transition-opacity duration-300 uppercase">Link Node</span>
    </a>
  </div>

  <div class="md:border-t md:border-slate-100 md:mx-4 md:pt-4">
    <button id="logout-btn" class="flex items-center gap-4 px-2 py-2 md:w-full cursor-pointer rounded-2xl hover:bg-red-50 transition-all group/user">
       <div class="size-11 rounded-full overflow-hidden border-2 border-white shadow-md ring-1 ring-slate-200 shrink-0">
         <img id="user-pp" src="https://ui-avatars.com/api/?name=Operator&background=0D8ABC&color=fff" class="size-full object-cover" />
       </div>
       <div class="md:opacity-0 md:group-hover:opacity-100 text-left transition-all duration-300 overflow-hidden max-md:hidden">
         <div id="user-name" class="text-xs font-black text-slate-800 truncate">Operator</div>
         <div class="text-[10px] text-red-500 font-bold uppercase tracking-tight opacity-0 group-hover/user:opacity-100 transition-opacity">Sign Out</div>
       </div>
       <span class="md:hidden text-[10px] font-bold text-slate-500">Me</span>
    </button>
  </div>
</nav>

<script>
  import { auth } from '../lib/firebase.js';
  import { onAuthStateChanged, signOut } from 'firebase/auth';

  const navItems = document.querySelectorAll('.n-item');
  const breadcrumbSection = document.getElementById('tb-section');

  // Handle Navigation State
  navItems.forEach(item => {
    item.addEventListener('click', () => {
      navItems.forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      const sectionName = item.querySelector('span:last-child')?.textContent;
      if (breadcrumbSection && sectionName) {
        breadcrumbSection.textContent = sectionName.toLowerCase();
      }
    });
  });

  // Firebase Auth State
  onAuthStateChanged(auth, (user) => {
    if (user) {
      const ppImgs = document.querySelectorAll('#user-pp') as NodeListOf<HTMLImageElement>;
      const nameEls = document.querySelectorAll('#user-name');
      
      ppImgs.forEach(img => {
        if (user.photoURL) img.src = user.photoURL;
      });
      nameEls.forEach(el => {
        el.textContent = user.displayName || user.email?.split('@')[0] || 'Operator';
      });
    }
  });

  document.getElementById('logout-btn')?.addEventListener('click', () => signOut(auth));
</script>

<style>
  /* Custom Active States */
  .n-item.active span:first-child {
    transform: scale(1.1);
  }

  /* Prevent text selection on nav */
  #sidenav {
    user-select: none;
    -webkit-user-select: none;
  }
</style>