---
// src/components/Sidebar.astro
---
<nav 
  id="sidenav" 
  class="group fixed z-60 bg-white/80 backdrop-blur-xl transition-all duration-300 ease-in-out border-slate-200/60
         /* Desktop: Vertical Sidebar Pill */
         md:inset-bs-1/2 md:-translate-y-1/2 md:inset-is-[14px] md:flex md:flex-col md:py-4 md:w-[72px] md:hover:w-[224px] md:rounded-full md:hover:rounded-[32px] md:max-h-[calc(100vh-48px)] md:border md:shadow-xl
         /* Phone: Full-Width Bottom Glass Bar */
         max-md:inset-be-0 max-md:inset-is-0 max-md:w-full max-md:h-[calc(72px+var(--sab))] max-md:flex max-md:flex-row max-md:items-start max-md:justify-around max-md:px-6 max-md:pt-3 max-md:border-t max-md:rounded-t-[32px] max-md:shadow-[0_-8px_30px_rgba(0,0,0,0.04)]"
>
  <div class="hidden md:flex h-11 items-center px-5 gap-3 shrink-0 mb-4">
    <div class="size-[30px] shrink-0 border-2 border-orange-600 rounded-[9px] rotate-45 flex items-center justify-center">
      <div class="size-1.5 bg-orange-600 rounded-[2px] -rotate-45"></div>
    </div>
    <span class="text-sm font-bold tracking-tight text-slate-900 opacity-0 group-hover:opacity-100 transition-opacity duration-300">
      ARK
    </span>
  </div>

  <div class="flex md:flex-col max-md:flex-row max-md:w-full max-md:justify-around max-md:items-center">
    <a href="#environment" class="n-item active group/item flex items-center gap-2.5 px-5 py-2 hover:bg-orange-50/50 transition-colors max-md:flex-col max-md:px-2">
      <span class="size-10 shrink-0 flex items-center justify-center text-slate-400 group-[.active]:text-orange-600 group-[.active]:bg-orange-50 group-[.active]:rounded-2xl transition-all">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>
      </span>
      <span class="text-[10px] md:text-xs font-bold text-slate-500 group-[.active]:text-orange-600 md:opacity-0 md:group-hover:opacity-100 transition-opacity whitespace-nowrap">Environment</span>
    </a>

    <a href="#gps" class="n-item group/item flex items-center gap-2.5 px-5 py-2 hover:bg-orange-50/50 transition-colors max-md:flex-col max-md:px-2">
      <span class="size-10 shrink-0 flex items-center justify-center text-slate-400 group-[.active]:text-orange-600 group-[.active]:max-md:bg-orange-50 group-[.active]:max-md:rounded-2xl transition-all">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 2v3M12 19v3M2 12h3M19 12h3"/></svg>
      </span>
      <span class="text-[10px] md:text-xs font-bold text-slate-500 group-[.active]:text-orange-600 md:opacity-0 md:group-hover:opacity-100 transition-opacity whitespace-nowrap">GPS</span>
    </a>

    <a href="#motion" class="n-item group/item flex items-center gap-2.5 px-5 py-2 hover:bg-orange-50/50 transition-colors max-md:flex-col max-md:px-2">
      <span class="size-10 shrink-0 flex items-center justify-center text-slate-400 group-[.active]:text-orange-600 group-[.active]:max-md:bg-orange-50 group-[.active]:max-md:rounded-2xl transition-all">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M13 2L3 14h9l-1 8 10-12h-9l1-8z"/></svg>
      </span>
      <span class="text-[10px] md:text-xs font-bold text-slate-500 group-[.active]:text-orange-600 md:opacity-0 md:group-hover:opacity-100 transition-opacity whitespace-nowrap">Motion</span>
    </a>
  </div>

  <div class="hidden md:flex flex-1"></div>

  <div class="md:border-t md:border-slate-100 md:mx-3.5 md:pt-2">
    <button id="logout-btn" class="flex items-center gap-2.5 px-2 py-2 md:w-full cursor-pointer rounded-2xl hover:bg-slate-50 transition-colors group/user">
       <div class="size-10 rounded-full overflow-hidden border-2 border-white shadow-sm ring-1 ring-slate-200 shrink-0 transition-transform active:scale-90">
         <img id="user-pp" src="https://lh3.googleusercontent.com/a/default-user=s80-p" class="size-full object-cover" />
       </div>
       <div class="md:opacity-0 md:group-hover:opacity-100 text-left transition-opacity overflow-hidden max-md:hidden">
         <div id="user-name" class="text-[11px] font-bold text-slate-700 truncate">Operator</div>
         <div class="text-[9px] text-slate-400 uppercase tracking-tighter group-hover/user:text-red-500 transition-colors">Sign Out</div>
       </div>
       <span class="md:hidden text-[10px] font-bold text-slate-500">Me</span>
    </button>
  </div>
</nav>

<script>
  import { auth } from '../lib/firebase.js';
  import { onAuthStateChanged, signOut } from 'firebase/auth';

  const navItems = document.querySelectorAll('.n-item');
  const breadcrumbSection = document.getElementById('tb-section');

  navItems.forEach(item => {
    item.addEventListener('click', () => {
      navItems.forEach(i => i.classList.remove('active'));
      item.classList.add('active');
      const sectionName = item.querySelector('span:last-child')?.textContent;
      if (breadcrumbSection && sectionName) {
        breadcrumbSection.textContent = sectionName.toLowerCase();
      }
    });
  });

  onAuthStateChanged(auth, (user) => {
    if (user) {
      const ppImgs = document.querySelectorAll('#user-pp');
      const nameEls = document.querySelectorAll('#user-name');
      
      ppImgs.forEach(img => {
        if (user.photoURL) (img as HTMLImageElement).src = user.photoURL;
      });
      nameEls.forEach(el => {
        el.textContent = user.displayName || user.email?.split('@')[0] || 'Operator';
      });
    }
  });

  document.getElementById('logout-btn')?.addEventListener('click', () => signOut(auth));
</script>

<style>
  /* Desktop Active Line Indicator */
  @media (min-width: 768px) {
    .n-item.active {
      background-color: var(--color-orange-50);
      border-inline-start: 3px solid var(--color-orange-600);
    }
  }
</style>