---
import '../styles/global.css';
import Sidebar from '../components/Sidebar.astro'; // Create this next

interface Props {
    title: string;
    showNav?: boolean; // New prop to hide sidebar on login
}

const { title, showNav = true } = Astro.props;
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
        <title>{title} | ARK</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;800&display=swap" rel="stylesheet">
    </head>
    <body class="antialiased overflow-x-hidden text-slate-900 bg-[#F4F7F9]">
        
        {showNav && <Sidebar />}

        <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-indigo-400/10 blur-[120px] rounded-full"></div>
            <div class="absolute bottom-[-5%] right-[-5%] w-[40%] h-[40%] bg-orange-400/10 blur-[100px] rounded-full"></div>
            <div class="absolute inset-0 opacity-[0.03] grain-overlay"></div>
        </div>

        <main id="app-content" class={`min-h-screen flex flex-col ${showNav ? 'pl-24 pr-6' : ''}`}>
            <slot />
        </main>
    </body>
</html>

<style is:global>
    .grain-overlay {
        background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 200 200' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.65'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    }
</style>