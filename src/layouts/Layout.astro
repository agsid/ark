---
import '../styles/global.css';
import Header from '../components/Header.astro';

interface Props {
    title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en" class="bg-[#F8FAFC]">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover" />
        <title>{title} | ARK</title>
        <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;500;800&display=swap" rel="stylesheet">
    </head>
    <body class="antialiased overflow-x-hidden text-slate-900">
        
        <Header />

        <div class="fixed inset-0 -z-10 overflow-hidden pointer-events-none">
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] bg-indigo-400/5 blur-[120px] rounded-full animate-pulse"></div>
            <div class="absolute bottom-[-5%] right-[-5%] w-[40%] h-[40%] bg-blue-400/5 blur-[100px] rounded-full"></div>
        </div>

        <main id="app-content" class="min-h-[calc(100-4rem)] flex flex-col">
            <slot />
        </main>

    </body>
</html>