---
import Sidebar from '../components/Sidebar.astro';
import Header from '../components/Header.astro';
import '../styles/global.css';
const { title = "ARK Dashboard" } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover, maximum-scale=1.0, user-scalable=no" />
  
  <link rel="manifest" href="/manifest.json" />
  <meta name="apple-mobile-web-app-capable" content="yes" />
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
  <meta name="theme-color" content="#f5f4f0" />
  <link rel="apple-touch-icon" href="/favicon.png" />
<link rel="icon" href="/favicon.png" type="image/x-icon" />
  <title>{title}</title>

  <script>
    import { auth, db } from '../lib/firebase.js';
    import { onAuthStateChanged } from 'firebase/auth';
    import { ref, onValue } from 'firebase/database';

    // Global Auth & Data Sync
    onAuthStateChanged(auth, (user) => {
      if (user) {
        const nodeId = localStorage.getItem('ark_linked_node');
        if (nodeId) {
          onValue(ref(db, `hardware/${nodeId}`), (snapshot) => {
            const data = snapshot.val();
            if (data) {
              window.dispatchEvent(new CustomEvent('ark-telemetry', { detail: data }));
              if (window.setLive) window.setLive(`ARK-${nodeId}`);
            }
          });
        }
      } else if (window.location.pathname !== '/login') {
        window.location.href = '/login';
      }
    });
  </script>
</head>

<body class="bg-[#f5f4f0] text-slate-700 font-sans antialiased min-h-screen">
<div class="w-full"><Sidebar /></div>
  <Header />
  
  <main 
    class="transition-all duration-500 ease-in-out
           /* Desktop: Shift for sidebar */a
           md:ml-[98px] md:pt-24 md:pb-10 md:pr-6 md:pl-2 
           /* Mobile: Centered content, extra bottom space for Nav Pill */
           max-md:px-4 max-md:pt-24 max-md:pb-32"
  >
    <div class="max-w-7xl mx-auto">
      <slot />
    </div>
  </main>

  <style is:global>
    :root {
      /* Safe area variables for Swift-like connection to iOS/Android hardware */
      --sat: env(safe-area-inset-top);
      --sab: env(safe-area-inset-bottom);
    }

    /* Prevent text selection to feel more like a native app */
    body {
      -webkit-tap-highlight-color: transparent;
      user-select: none;
    }

    /* Adjusting the Header for Mobile Notch */
    @media (max-width: 768px) {
      #topbar {
        top: calc(12px + var(--sat));
        left: 14px;
        right: 14px;
        height: 52px;
      }
    }
  </style>
</body>
</html>